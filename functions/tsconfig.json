{
  "compilerOptions": {
    "module": "commonjs",        // ← change from NodeNext
    "moduleResolution": "node",  // ← change from nodenext
    "esModuleInterop": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "outDir": "lib",
    "sourceMap": true,
    "strict": true,
    "target": "es2017"
  },
  "compileOnSave": true,
  "include": ["src"]
}
